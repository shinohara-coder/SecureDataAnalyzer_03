<Window x:Class="SecureDataAnalyzer_02.WPF.Views.Components.CsvImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSVファイルの読み込み" Height="350" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F3F3F3">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="解析するCSVファイルを選択してください" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

        <Border Grid.Row="1" x:Name="DropArea" 
                Background="White" BorderBrush="#FFCCCCCC" BorderThickness="2" 
                CornerRadius="10" AllowDrop="True"
                Drop="DropArea_Drop" 
                DragOver="DropArea_DragOver" 
                DragLeave="DropArea_DragLeave">
            <Border BorderBrush="#FFAAAAAA" BorderThickness="1" Margin="5" CornerRadius="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📥" FontSize="48" HorizontalAlignment="Center" Foreground="#FF999999"/>
                    <TextBlock Text="ここにCSVファイルをドロップ" Margin="0,10,0,0" FontSize="14" Foreground="#FF666666"/>
                    <TextBlock Text="(CSV形式のみ対応)" FontSize="11" HorizontalAlignment="Center" Foreground="#FF999999" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="エクスプローラーで参照..." Width="160" Height="35" Margin="0,0,10,0" Click="BrowseBtn_Click" Cursor="Hand"/>
            <Button Content="キャンセル" Width="80" Height="35" Click="CancelBtn_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>