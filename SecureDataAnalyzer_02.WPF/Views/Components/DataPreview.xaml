<UserControl x:Class="SecureDataAnalyzer_02.WPF.Views.Components.DataPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SecureDataAnalyzer_02.WPF.Views.Components">

    <UserControl.Resources>
        <!-- ラベルスタイル -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5A6A80"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
        <!-- 値スタイル -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1A2233"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
        </Style>
        <!-- セクション見出しスタイル -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A6FA5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <!-- 行区切り -->
        <Style x:Key="RowSeparator" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E6EF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <!-- ══════════════════════════════════════════
             候補ポップアップ用 DataTemplate
             ══════════════════════════════════════════ -->

        <!-- 通常の得意先行 -->
        <DataTemplate x:Key="CustomerItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Code}"
                           FontFamily="Consolas" FontSize="11.5"
                           Foreground="#4A6FA5" FontWeight="Bold"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Name1}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding KanaName}"
                           Foreground="#6B7280" FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </DataTemplate>

        <!-- 「次のN件を表示」ボタン行 -->
        <DataTemplate x:Key="LoadMoreItemTemplate">
            <Border Background="#EEF3FB"
                    CornerRadius="3" Padding="8,6">
                <TextBlock Text="{Binding Label}"
                           Foreground="#2D5FA8" FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </Border>
        </DataTemplate>

        <!-- テンプレートセレクター -->
        <local:SuggestItemTemplateSelector x:Key="SuggestTemplateSelector"
            CustomerTemplate="{StaticResource CustomerItemTemplate}"
            LoadMoreTemplate="{StaticResource LoadMoreItemTemplate}"/>

    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <!-- 検索バー -->
            <RowDefinition Height="Auto"/>
            <!-- 詳細レコードパネル -->
            <RowDefinition Height="Auto"/>
            <!-- DataGrid CSV プレビュー -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════
             Row 0: 検索バー
             ══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#EAEEF5"
                BorderBrush="#B0BDD0" BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="SearchBox"
                             Height="32" FontSize="13"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             BorderBrush="#90A0B8"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown"
                             GotFocus="SearchBox_GotFocus"
                             LostFocus="SearchBox_LostFocus"/>

                    <TextBlock x:Name="SearchPlaceholder"
                               Text="🔍  得意先名・ひらがな・略称で検索…"
                               Foreground="#90A0B8" FontSize="12.5"
                               VerticalAlignment="Center" Margin="10,0"
                               IsHitTestVisible="False"/>

                    <!-- 候補ポップアップ -->
                    <Popup x:Name="SuggestPopup"
                           PlacementTarget="{Binding ElementName=SearchBox}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="True"
                           IsOpen="False">
                        <Border Background="White"
                                BorderBrush="#90A0B8" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                                  Opacity="0.18" Direction="270"/>
                            </Border.Effect>
                            <ListBox x:Name="SuggestList"
                                     MinWidth="520" MaxHeight="320"
                                     FontSize="12.5"
                                     KeyDown="SuggestList_KeyDown"
                                     PreviewMouseLeftButtonDown="SuggestList_PreviewMouseLeftButtonDown"
                                     ItemTemplateSelector="{StaticResource SuggestTemplateSelector}"
                                     Background="White" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,5"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E8EEF8"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#C5D8F5"/>
                                                <Setter Property="Foreground" Value="#1A1A1A"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <!-- 全件表示ボタン -->
                <Button Grid.Column="1" x:Name="ShowAllBtn"
                        Content="全件表示"
                        Width="90" Height="32" Margin="8,0,0,0"
                        FontSize="12"
                        Background="#4A6FA5" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="ShowAllBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="3" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3A5F95"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#2A4F85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════
             Row 1: 得意先 詳細レコードパネル
             ══════════════════════════════════════════════ -->
        <Border x:Name="DetailPanel"
                Grid.Row="1"
                Visibility="Collapsed"
                Background="#F4F7FC"
                BorderBrush="#B0C0D8" BorderThickness="0,0,0,2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── ヘッダー行 ── -->
                <Border Grid.Row="0"
                        Background="#4A6FA5" Padding="12,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="【" Foreground="White" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="DetailCode"
                                       Foreground="#CFDFFF" FontWeight="Bold"
                                       FontFamily="Consolas" FontSize="14"/>
                            <TextBlock Text="】" Foreground="White" FontWeight="Bold"
                                       FontSize="14" Margin="0,0,12,0"/>
                            <TextBlock x:Name="DetailName1"
                                       Foreground="White" FontWeight="Bold" FontSize="15"/>
                        </StackPanel>

                        <Button Grid.Column="1" x:Name="CloseDetailBtn"
                                Content="✕"
                                Width="26" Height="26"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#CFDFFF" FontSize="14"
                                Cursor="Hand"
                                Click="CloseDetailBtn_Click"/>
                    </Grid>
                </Border>

                <!-- ── フィールドグリッド（スクロール可） ── -->
                <ScrollViewer Grid.Row="1"
                              MaxHeight="240"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,8,12,10">

                        <!-- ▸ 基本情報 -->
                        <TextBlock Text="■ 基本情報" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="得意先略称" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailRyakusho" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="取引先名ひらがな" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailKana" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="得意先名２" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailName2"
                                           Grid.ColumnSpan="3" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>

                        <!-- ▸ 住所・連絡先 -->
                        <TextBlock Text="■ 住所・連絡先" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="郵便番号" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailPostal" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="電話番号" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailTel" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ＦＡＸ番号" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailFax" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="住所１" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailAddr1" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="住所２" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailAddr2" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="住所３" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailAddr3" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>

                        <!-- ▸ 管理情報 -->
                        <TextBlock Text="■ 管理情報" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="納品先コード" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailNohinsakiCode" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="担当者コード" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailTantoshaCode" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="与信限度額" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailSinyoLimit" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="重量表示" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailWeightDisplay" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>

                        <!-- ▸ 単価・金額処理区分 -->
                        <TextBlock Text="■ 単価・金額処理区分" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="単価処理区分" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailTankaKubun1" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="単価処理単位" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailTankaUnit1" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="区分(1kg未満)" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailTankaKubun2" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="単位(1kg未満)" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailTankaUnit2" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="金額処理区分" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailKingakuKubun" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="区分(切板以外)" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailTankaKubun3" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="単位(切板以外)" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailTankaUnit3" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>

                        <!-- ▸ 消費税処理 -->
                        <TextBlock Text="■ 消費税処理" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="消費税計算区分" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailShouhizeiKubun" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="消費税計算単位" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailShouhizeiUnit" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="消費税分解区分" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailShouhizeiBunkai" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>

                        <!-- ▸ パスワード管理 -->
                        <TextBlock Text="■ パスワード管理" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource RowSeparator}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="新PW適用年月日" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="1" x:Name="DetailPwDate" Style="{StaticResource FieldValue}"/>
                                <TextBlock Grid.Column="2" Text="新PW適用時刻" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Grid.Column="3" x:Name="DetailPwTime" Style="{StaticResource FieldValue}"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════
             Row 2: CSV プレビュー DataGrid
             ══════════════════════════════════════════════ -->
        <DataGrid x:Name="PreviewGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  AlternatingRowBackground="#F5F7FA"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  FontSize="12"
                  ColumnHeaderHeight="28"
                  RowHeight="24">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#DDE3ED"/>
                    <Setter Property="Foreground" Value="#2D3A4A"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="6,4"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <TextBlock x:Name="EmptyMessage"
                   Grid.Row="2"
                   Text="CSV を読み込むと、ここにデータが表示されます"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Foreground="#B0BDD0" FontSize="14"
                   Visibility="Visible"/>
    </Grid>
</UserControl>
