<UserControl x:Class="SecureDataAnalyzer_02.WPF.Views.Components.GraphDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Background="#E9E9E9">
        <Border x:Name="Graph2" Height="200" Margin="5" Background="White" BorderBrush="Silver" BorderThickness="1">
            <Grid>
                <TextBlock Text="領域2: グラフ" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Button Content="×" HorizontalAlignment="Right" VerticalAlignment="Top" Width="20" Height="20" Margin="2" 
                        Click="HideGraph_Click" Tag="Graph2" Background="#FFF0F0F0"/>
            </Grid>
        </Border>

        <Border x:Name="Graph3" Height="200" Margin="5" Background="White" BorderBrush="Silver" BorderThickness="1">
            <Grid>
                <TextBlock Text="領域3: グラフ" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Button Content="×" HorizontalAlignment="Right" VerticalAlignment="Top" Width="20" Height="20" Margin="2" 
                        Click="HideGraph_Click" Tag="Graph3" Background="#FFF0F0F0"/>
            </Grid>
        </Border>

        <Border x:Name="Graph4" Height="200" Margin="5" Background="White" BorderBrush="Silver" BorderThickness="1">
            <Grid>
                <TextBlock Text="領域4: グラフ" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Button Content="×" HorizontalAlignment="Right" VerticalAlignment="Top" Width="20" Height="20" Margin="2" 
                        Click="HideGraph_Click" Tag="Graph4" Background="#FFF0F0F0"/>
            </Grid>
        </Border>

        <Border x:Name="Graph5" Height="200" Margin="5" Background="White" BorderBrush="Silver" BorderThickness="1">
            <Grid>
                <TextBlock Text="領域5: グラフ" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Button Content="×" HorizontalAlignment="Right" VerticalAlignment="Top" Width="20" Height="20" Margin="2" 
                        Click="HideGraph_Click" Tag="Graph5" Background="#FFF0F0F0"/>
            </Grid>
        </Border>

        <Border x:Name="Graph6" Height="200" Margin="5" Background="White" BorderBrush="Silver" BorderThickness="1">
            <Grid>
                <TextBlock Text="領域6: グラフ" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Button Content="×" HorizontalAlignment="Right" VerticalAlignment="Top" Width="20" Height="20" Margin="2" 
                        Click="HideGraph_Click" Tag="Graph6" Background="#FFF0F0F0"/>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>