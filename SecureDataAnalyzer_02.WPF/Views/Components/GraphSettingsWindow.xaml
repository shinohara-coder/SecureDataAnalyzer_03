<Window x:Class="SecureDataAnalyzer_02.WPF.Views.Components.GraphSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="グラフ作成設定" Height="380" Width="400" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F9F9F9">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="グラフ化するデータの選択" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="X軸 (項目名):" Margin="0,5,0,2"/>
            <ComboBox x:Name="ComboX" Height="30" Margin="0,0,0,10"/>

            <TextBlock Text="Y軸 (数値):" Margin="0,5,0,2"/>
            <ComboBox x:Name="ComboY" Height="30" Margin="0,0,0,10"/>

            <TextBlock Text="グラフ形式:" Margin="0,5,0,2"/>
            <ComboBox x:Name="ComboType" Height="30" Margin="0,0,0,20">
                <ComboBoxItem Content="棒グラフ" IsSelected="True"/>
                <ComboBoxItem Content="折れ線グラフ"/>
                <ComboBoxItem Content="円グラフ"/>
            </ComboBox>

            <Button Content="グラフを表示" Height="40" Background="#0078D7" Foreground="White" 
                    FontWeight="Bold" Click="ShowGraph_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>