<UserControl x:Class="SecureDataAnalyzer_02.WPF.Views.Components.RibbonPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="80">
    <Border Background="#F3F3F3" BorderBrush="Gray" BorderThickness="0,0,0,1">
        <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="表示グラフ：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <CheckBox Content="領域2" IsChecked="True" Margin="5" Click="CheckBox_Click" Tag="2"/>
                <CheckBox Content="領域3" IsChecked="True" Margin="5" Click="CheckBox_Click" Tag="3"/>
                <CheckBox Content="領域4" IsChecked="True" Margin="5" Click="CheckBox_Click" Tag="4"/>
                <CheckBox Content="領域5" IsChecked="True" Margin="5" Click="CheckBox_Click" Tag="5"/>
                <CheckBox Content="領域6" IsChecked="True" Margin="5" Click="CheckBox_Click" Tag="6"/>
            </StackPanel>

            <Button x:Name="ShowGraphBtn" 
                    Content="グラフエリアを表示" 
                    Padding="10,5" Margin="10"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Visibility="Collapsed"
                    Click="ShowGraphBtn_Click"/>
        </Grid>
    </Border>
</UserControl>