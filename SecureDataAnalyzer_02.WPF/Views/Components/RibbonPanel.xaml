<UserControl x:Class="SecureDataAnalyzer_02.WPF.Views.Components.RibbonPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="80">
    <Border Background="#F3F3F3" BorderBrush="Gray" BorderThickness="0,0,0,1">
        <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                <Button x:Name="CsvImportBtn" Content="得意先マスター" Width="110" Height="30" Click="CsvImportBtn_Click"/>
                <Button x:Name="CreateGraphBtn" Content="グラフ作成" Width="100" Height="30" Margin="10,0,0,0" Click="CreateGraphBtn_Click"/>
                <Button x:Name="DailyCsvBtn" Content="デイリーCSV読込" Width="120" Height="30" Margin="10,0,0,0" Click="DailyCsvBtn_Click"/>
                <Button x:Name="ExecuteBtn" Content="実行・更新" Width="100" Height="30" Margin="10,0,0,0" Background="#3A7A5A" Foreground="White" BorderThickness="0" Click="ExecuteBtn_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button x:Name="ToggleGraphAreaBtn" Content="全グラフ非表示" Width="110" Height="40" Margin="0,0,15,0" Click="ToggleGraphAreaBtn_Click" Background="#FFEAEAEA"/>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="表示グラフ：" FontWeight="Bold" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="Chk2" Content="グラフ1" IsChecked="True" Margin="0,2,10,2" Click="CheckBox_Click" Tag="2"/>
                        <CheckBox x:Name="Chk3" Content="グラフ2" IsChecked="True" Margin="0,2,10,2" Click="CheckBox_Click" Tag="3"/>
                        <CheckBox x:Name="Chk4" Content="グラフ3" IsChecked="True" Margin="0,2,10,2" Click="CheckBox_Click" Tag="4"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="Chk5" Content="グラフ4" IsChecked="True" Margin="0,2,10,2" Click="CheckBox_Click" Tag="5"/>
                        <CheckBox x:Name="Chk6" Content="グラフ5" IsChecked="True" Margin="0,2,10,2" Click="CheckBox_Click" Tag="6"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>