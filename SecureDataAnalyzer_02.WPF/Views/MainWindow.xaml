<Window x:Class="SecureDataAnalyzer_02.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:comp="clr-namespace:SecureDataAnalyzer_02.WPF.Views.Components"
        Title="SecureDataAnalyzer - 神和アルミ様モック" Height="700" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <comp:RibbonPanel x:Name="MyRibbon" Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                <ColumnDefinition x:Name="GraphColumn" Width="1*"/>
            </Grid.ColumnDefinitions>

            <comp:DataPreview Grid.Column="0"/>
            <comp:DataPreview x:Name="MyPreview" Grid.Column="0"/>

            <GridSplitter x:Name="MySplitter" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="5" Background="#CCC"/>

            <Grid x:Name="GraphArea" Grid.Column="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <comp:GraphDisplay x:Name="MyGraphContent" />
                </ScrollViewer>
            </Grid>

            <Button x:Name="ToggleRibbonBtn" Content="▲" VerticalAlignment="Top" HorizontalAlignment="Left" Width="30" Height="25" Margin="5,5,0,0" Click="ToggleRibbon_Click"/>
        </Grid>
    </Grid>
</Window>